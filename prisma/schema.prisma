// ============================================================
// LockBox — Prisma Schema
// ============================================================
// Sections:
//   1. Generator & Datasource
//   2. NextAuth Core Models (User, Account, Session)
//   3. User Preferences
//   4. Financial Models (Vault, Transaction, Category)
//   5. LockBox Core Models (Box, Keyholder, UnlockRequest)
// ============================================================

// ------------------------------------------------------------
// 1. GENERATOR & DATASOURCE
// ------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------
// 2. NEXTAUTH CORE MODELS
// ------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  // Relations
  accounts     Account[]
  sessions     Session[]
  preferences  Preferences?
  vaults       Vault[]
  boxes        Box[]
  transactions Transaction[]
  categories   Category[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Unit BaaS
unitCustomerId String? // Unit customer ID assigned after KYC
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ------------------------------------------------------------
// 3. USER PREFERENCES
// ------------------------------------------------------------

model Preferences {
  id     String @id @default(cuid())
  userId String @unique

  currency      String  @default("USD")
  language      String  @default("en")
  theme         String  @default("light")
  notifications Boolean @default(true)
  dailySummary  Boolean @default(true)
  pushApprovals Boolean @default(true)

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ------------------------------------------------------------
// 4. FINANCIAL MODELS
// ------------------------------------------------------------

// Top-level account container for a user
model Vault {
  id      String @id @default(cuid())
  name    String
  balance Int    @default(0) // stored in cents

  userId String
  user   User   @relation(fields: [userId], references: [id])

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Ledger of all money movement across vaults and boxes
model Transaction {
  id          String   @id @default(cuid())
  type        String   // DEPOSIT | WITHDRAWAL | TRANSFER | LOCK | UNLOCK
  amount      Int      // stored in cents
  description String?
  postedAt    DateTime @default(now())

  userId     String
  user       User      @relation(fields: [userId], references: [id])
  vaultId    String?
  vault      Vault?    @relation(fields: [vaultId], references: [id])
  boxId      String?
  box        Box?      @relation(fields: [boxId], references: [id])
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([userId, postedAt])
}

model Category {
  id   String @id @default(cuid())
  name String
  type String // INCOME | EXPENSE

  userId       String
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@index([userId, type])
}

// ------------------------------------------------------------
// 5. LOCKBOX CORE MODELS
// ------------------------------------------------------------

// Box — a purpose-specific locked sub-account
// Status flow: CREATED → FUNDING → LOCKED → UNLOCK_PENDING → UNLOCKED → CLOSED
model Box {
  id           String    @id @default(cuid())
  name         String
  description  String?
  status       String    @default("CREATED") // see status flow above
  balance      Int       @default(0)          // stored in cents
  targetAmount Int?                            // stored in cents, optional goal
  lockUntil    DateTime?                       // null until box is locked

  userId String
  user   User   @relation(fields: [userId], references: [id])

  // One optional keyholder per box — the core product differentiator
  keyholder Keyholder?

  // All unlock attempts against this box
  unlockRequests UnlockRequest[]

  // Transactions scoped to this box
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])

// Unit BaaS
unitAccountId String? // Unit deposit account ID for this safe deposit box

  @@index([status])
}

// Keyholder — trusted person who must approve early unlock requests
// SECURITY: inviteToken is only for the initial invite email.
// Never expose approvalToken (on UnlockRequest) to the box owner.
model Keyholder {
  id    String  @id @default(cuid())
  boxId String  @unique
  email String
  name  String?

  // True once the keyholder clicks accept in their invite email
  accepted Boolean @default(false)

  // Token sent in the keyholder invite email only
  inviteToken String @unique @default(cuid())

  box Box @relation(fields: [boxId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([inviteToken])
}

// UnlockRequest — created when a user attempts to unlock before lockUntil
// SECURITY: approvalToken is generated server-side and sent ONLY to the
// keyholder. It must never be returned in any API response to the box owner.
model UnlockRequest {
  id         String    @id @default(cuid())
  boxId      String
  reason     String    // user-provided reason for early unlock
  reflection String?   // answer to reflection prompt shown before submitting
  status     String    @default("PENDING") // PENDING | APPROVED | DENIED

  // Sent only to the keyholder — never exposed to the box owner under any circumstance
  approvalToken String @unique @default(cuid())

  // User cannot re-request until this timestamp passes
  cooldownUntil DateTime?

  requestedAt DateTime  @default(now())
  resolvedAt  DateTime? // set when keyholder approves or denies

  box Box @relation(fields: [boxId], references: [id])

  updatedAt DateTime @updatedAt

  @@index([boxId])
  @@index([approvalToken])
  @@index([status])
}