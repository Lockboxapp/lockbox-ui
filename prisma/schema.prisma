// ============================================================
// LockBox — Prisma Schema
// ============================================================
// Sections:
//   1. Generator & Datasource
//   2. NextAuth Core Models (User, Account, Session)
//   3. User Preferences
//   4. Financial Models (Vault, Transaction, Category)
//   5. LockBox Core Models (Box, Keyholder, UnlockRequest)
// ============================================================

// ------------------------------------------------------------
// 1. GENERATOR & DATASOURCE
// ------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------
// ENUMS
// ------------------------------------------------------------

enum KeyholderScopeType {
  ALL
  SELECTED
}

enum KeyholderRelationshipStatus {
  PENDING
  ACTIVE
  PAUSED
  REVOKED
}

enum KeyholderOTPPurpose {
  INVITE
  APPROVAL
}

enum KeyholderSessionPurpose {
  INVITE
  APPROVAL
}

enum LockType {
  HARD
  SOFT
  KEYHOLDER
}

enum RequestType {
  UNLOCK
  TRANSFER
}
// ------------------------------------------------------------
// 2. NEXTAUTH CORE MODELS
// ------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  // Relations
  accounts               Account[]
  sessions               Session[]
  keyholderRelationships KeyholderRelationship[]
  preferences            Preferences?
  vaults                 Vault[]
  boxes                  Box[]
  transactions           Transaction[]
  categories             Category[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Unit BaaS
  unitCustomerId String? // Unit customer ID assigned after KYC

  // Admin
  isAdmin Boolean @default(false)

  // Sprint 9 — onboarding completion + account restriction
  onboardingCompletedAt DateTime?
  isRestricted          Boolean   @default(false)
  restrictedAt          DateTime?
  restrictedReason      String?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ------------------------------------------------------------
// 3. USER PREFERENCES
// ------------------------------------------------------------

model Preferences {
  id     String @id @default(cuid())
  userId String @unique

  currency      String  @default("USD")
  language      String  @default("en")
  theme         String  @default("light")
  notifications Boolean @default(true)
  dailySummary  Boolean @default(true)
  pushApprovals Boolean @default(true)

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ------------------------------------------------------------
// 4. FINANCIAL MODELS
// ------------------------------------------------------------

// Top-level account container for a user
model Vault {
  id      String @id @default(cuid())
  name    String
  balance Int    @default(0) // stored in cents

  userId String
  user   User   @relation(fields: [userId], references: [id])

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Ledger of all money movement across vaults and boxes
model Transaction {
  id          String   @id @default(cuid())
  type        String // DEPOSIT | WITHDRAWAL | TRANSFER | LOCK | UNLOCK
  amount      Int // stored in cents
  description String?
  postedAt    DateTime @default(now())

  userId     String
  user       User      @relation(fields: [userId], references: [id])
  vaultId    String?
  vault      Vault?    @relation(fields: [vaultId], references: [id])
  boxId      String?
  box        Box?      @relation(fields: [boxId], references: [id])
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([userId, postedAt])
}

model Category {
  id   String @id @default(cuid())
  name String
  type String // INCOME | EXPENSE

  userId       String
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@index([userId, type])
}

// ------------------------------------------------------------
// 5. LOCKBOX CORE MODELS
// ------------------------------------------------------------

// Box — a purpose-specific locked sub-account
// Status flow: CREATED → FUNDING → LOCKED → UNLOCK_PENDING → UNLOCKED → CLOSED
model Box {
  id           String    @id @default(cuid())
  name         String
  description  String?
  status       String    @default("CREATED") // see status flow above
  lockType   LockType  @default(SOFT)
  balance      Int       @default(0) // stored in cents
  lockedAmount Int       @default(0) // cents — how much of balance is locked (source of truth for partial lock)
  targetAmount Int? // stored in cents, optional goal
  lockUntil    DateTime? // null until box is locked
  isPriority   Boolean   @default(false) // manually pinned to priority by user
  isWallet     Boolean   @default(false) // one per user, auto-created on signup
  isClosed     Boolean   @default(false) // existence state, separate from lock lifecycle

  userId String
  user   User   @relation(fields: [userId], references: [id])

  // One optional keyholder per box — the core product differentiator
  keyholderScopes KeyholderRelationshipBox[]

  // All unlock attempts against this box
  unlockRequests UnlockRequest[]

  // Transactions scoped to this box
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Unit BaaS
  unitAccountId String? // Unit deposit account ID for this safe deposit box

  @@index([userId])
  @@index([status])
}

// Keyholder — trusted person who must approve early unlock requests
// SECURITY: inviteToken is only for the initial invite email.
// Never expose approvalToken (on UnlockRequest) to the box owner.

// UnlockRequest — created when a user attempts to unlock before lockUntil
// SECURITY: approvalToken is generated server-side and sent ONLY to the
// keyholder. It must never be returned in any API response to the box owner.
model UnlockRequest {
  id         String  @id @default(cuid())
  boxId      String
  reason     String // user-provided reason for early unlock
  reflection String? // answer to reflection prompt shown before submitting
  status     String  @default("PENDING") // PENDING | APPROVED | DENIED

  // Sprint 6 — request can be UNLOCK (full self-access) or TRANSFER (keyholder-approved box→box)
  requestType      RequestType @default(UNLOCK)
  transferAmount   Int? // cents, TRANSFER type only
  destinationBoxId String? // TRANSFER type only

  // Sent only to the keyholder — never exposed to the box owner under any circumstance
  approvalToken String @unique @default(cuid())

  // User cannot re-request until this timestamp passes
  cooldownUntil DateTime?

  requestedAt DateTime  @default(now())
  resolvedAt  DateTime? // set when keyholder approves or denies

  box Box @relation(fields: [boxId], references: [id])

  updatedAt DateTime @updatedAt

  @@index([boxId])
  @@index([approvalToken])
  @@index([status])
}

// ------------------------------------------------------------
// 6. KEYHOLDER SYSTEM
// ------------------------------------------------------------

// Who the keyholder is as a person — separate from any relationship or box
model KeyholderProfile {
  id        String   @id @default(cuid())
  email     String   @unique // always stored lowercase
  name      String?
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  relationships KeyholderRelationship[]
  otps          KeyholderOTP[]
  sessions      KeyholderSession[]

  @@index([email])
}

// The permission relationship between a LockBox user and a keyholder
model KeyholderRelationship {
  id              String                      @id @default(cuid())
  userId          String
  profileId       String
  scopeType       KeyholderScopeType          @default(ALL)
  status          KeyholderRelationshipStatus @default(PENDING)
  inviteToken     String                      @unique @default(cuid())
  inviteExpiresAt DateTime?
  acceptedAt      DateTime?
  revokedAt       DateTime?
  safetyMode      Boolean                     @default(false)
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  user    User                       @relation(fields: [userId], references: [id])
  profile KeyholderProfile           @relation(fields: [profileId], references: [id])
  boxes   KeyholderRelationshipBox[]

  @@index([userId])
  @@index([profileId])
  @@index([userId, profileId])
  @@index([inviteToken])
  @@index([status])
}

// Join table — only populated when scopeType = SELECTED
model KeyholderRelationshipBox {
  id             String @id @default(cuid())
  relationshipId String
  boxId          String

  relationship KeyholderRelationship @relation(fields: [relationshipId], references: [id])
  box          Box                   @relation(fields: [boxId], references: [id])

  @@unique([relationshipId, boxId])
  @@index([relationshipId])
  @@index([boxId])
}

// OTP for keyholder identity verification — code stored as bcrypt hash
model KeyholderOTP {
  id        String              @id @default(cuid())
  email     String // always lowercase, delivery target
  profileId String? // linked after profile exists
  codeHash  String // bcrypt hash of 6-digit code — never store raw
  token     String // the approvalToken or inviteToken this OTP is for
  purpose   KeyholderOTPPurpose
  expiresAt DateTime
  used      Boolean             @default(false)
  attempts  Int                 @default(0) // max 3 before lockout
  createdAt DateTime            @default(now())

  profile KeyholderProfile? @relation(fields: [profileId], references: [id])

  @@index([email])
  @@index([token])
}

// Short-lived verified session after OTP — grants access to approve/deny
model KeyholderSession {
  id           String                  @id @default(cuid())
  email        String // always lowercase
  profileId    String? // linked after profile exists
  sessionToken String                  @unique @default(cuid())
  sourceToken  String // the approvalToken or inviteToken
  purpose      KeyholderSessionPurpose
  expiresAt    DateTime
  createdAt    DateTime                @default(now())

  profile KeyholderProfile? @relation(fields: [profileId], references: [id])

  @@index([email])
  @@index([sessionToken])
}

// Audit log — every keyholder action must be recorded
model AuditEvent {
  id        String   @id @default(cuid())
  actor     String // USER | KEYHOLDER | SYSTEM | ADMIN
  actorId   String? // userId, profileId, or null for system
  action    String // INVITE_SENT | OTP_SENT | OTP_VERIFIED | RELATIONSHIP_ACCEPTED | REQUEST_APPROVED | REQUEST_DENIED | SESSION_CREATED | SELF_KEYHOLDER_BLOCKED
  targetId  String? // boxId, relationshipId, unlockRequestId
  metadata  String? // JSON string with before/after state
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

// Waitlist email captures
model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([email])
}

// Password reset tokens
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}