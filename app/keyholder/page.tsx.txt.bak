// app/keyholder/page.tsx
"use client";

import { useMemo } from "react";

export default function KeyholderPage({
  searchParams,
}: {
  searchParams: { id?: string; amount?: string; vaultId?: string };
}) {
  const id = searchParams?.id ?? "";
  const amount = searchParams?.amount ?? "";
  const vaultId = searchParams?.vaultId ?? "";

  const title = useMemo(() => {
    if (!id) return "Unlock request";
    return `Request ${id.slice(-6)}`;
  }, [id]);

  return (
    <main className="min-h-screen max-w-md mx-auto p-6">
      <h1 className="text-2xl font-semibold mb-2">{title}</h1>
      <p className="text-gray-600 mb-6">
        This is a public preview page for keyholders. The full approval flow
        isn’t wired to your app state yet, but the link now resolves so you
        won’t get a 404.
      </p>

      <div className="rounded-xl border p-4 space-y-2">
        <div className="text-sm">
          <span className="text-gray-500">Vault:</span>{" "}
          <span className="font-medium">{vaultId || "(unknown)"}</span>
        </div>
        <div className="text-sm">
          <span className="text-gray-500">Amount:</span>{" "}
          <span className="font-medium">{amount ? `$${amount}` : "(unknown)"}</span>
        </div>
        <div className="text-sm">
          <span className="text-gray-500">Request ID:</span>{" "}
          <span className="font-mono">{id || "(missing)"}</span>
        </div>
      </div>

      <div className="grid grid-cols-2 gap-3 mt-6">
        <button
          className="py-3 rounded-xl bg-emerald-600 text-white"
          onClick={() => alert("Approve (demo-only): Wire to API later.")}
        >
          Approve
        </button>
        <button
          className="py-3 rounded-xl bg-rose-600 text-white"
          onClick={() => alert("Reject (demo-only): Wire to API later.")}
        >
          Reject
        </button>
      </div>

      <p className="text-xs text-gray-500 mt-6">
        Tip: The app currently generates links like
        <br />
        <code className="font-mono">
          /keyholder?id=123&amount=100&vaultId=rent
        </code>
      </p>
    </main>
  );
}
